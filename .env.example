# Développement local (SQLite)
DATABASE_URL="file:./dev.db"

# Production VPS (PostgreSQL) — décommenter et adapter
# DATABASE_URL="postgresql://africanconnect:MOT_DE_PASSE@localhost:5432/africanconnect"

AUTH_SECRET="generez-un-secret-aleatoire-32-caracteres-minimum"
NEXTAUTH_URL="https://africanconnect.online"
AUTH_TRUST_HOST=true

# SEO — URL canonique du site (prod)
NEXT_PUBLIC_SITE_URL="https://africanconnect.online"

# Monétisation (désactivé par défaut — voir docs/MONETISATION.md)
# BILLING_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM_MONTHLY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
